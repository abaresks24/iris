# Backend (the Derive signer service)
NEXT_PUBLIC_API_URL=http://localhost:8799

# Privy — wallet + embedded wallets + cross-chain funding
# Create an app at https://dashboard.privy.io and paste the App ID.
# Without it the app still runs (trade flow works via the backend), but
# wallet connect + funding are disabled.
NEXT_PUBLIC_PRIVY_APP_ID=

# LI.FI — cross-chain bridge/swap quotes (one-tx deposit → USDC on Derive Chain)
# Optional API key (higher rate limits). For the ETHGlobal Composer track set
# the staging endpoint per the bounty instructions.
NEXT_PUBLIC_LIFI_API_KEY=
NEXT_PUBLIC_LIFI_INTEGRATOR=iris

# Derive Chain (OP-Stack L2) — settlement lands here in USDC
NEXT_PUBLIC_DERIVE_CHAIN_ID=957
NEXT_PUBLIC_DERIVE_RPC=https://rpc.lyra.finance
